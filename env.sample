##################################
# OpenSpec-Builder
##################################

# HTTP server port. Defaults to 3000.
PORT=3000

# SQLite database path. Defaults to data/openspec-builder.sqlite.
DATABASE_URL=data/openspec-builder.sqlite

# CORS origin for API calls. Use * for a trusted home-lab LAN, or lock this down.
CORS_ORIGIN=*

##################################
# GitHub publishing helpers
##################################

# Optional: used only when publishing this app to GitHub with gh.
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=openspec-builder
GITHUB_REPOSITORY=your-github-user-or-org/openspec-builder
GITHUB_REPO_LINK=https://github.com/your-github-user-or-org/openspec-builder

# Optional: GitHub personal access token for gh auth.
# Never commit a real token.
GITHUB_PERSONAL_KEY=
